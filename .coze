[project]
requires = [ "nodejs-24" ]
template = "nextjs"
version = "legacy"
appliedPatches = [ "nextjs/replace-npx-with-pnpm@0.0.13" ]

[dev]
build = [ "bash", "./scripts/prepare.sh" ]
run = [ "bash", "./scripts/dev.sh" ]
deps = [ "git" ]

[deploy]
build = [ "bash", "./scripts/build.sh" ]
run = [ "bash", "./scripts/start.sh" ]
deps = [ "git" ]
